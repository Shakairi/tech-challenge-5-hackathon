# ── Firebase ──────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha com os dados
# do seu projeto em https://console.firebase.google.com

NEXT_PUBLIC_FIREBASE_API_KEY=sua-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abc123

# ── Ativar Firebase (true) ou localStorage (false) ────────
NEXT_PUBLIC_USE_FIREBASE=false
